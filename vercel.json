{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/pictan-next/index.html",
      "has": [
        { "type": "host", "value": "pictan.corita.jp" }
      ]
    },
    {
      "source": "/:path*",
      "destination": "/pictan-next/:path*",
      "has": [
        { "type": "host", "value": "pictan.corita.jp" }
      ]
    }
  ]
}
